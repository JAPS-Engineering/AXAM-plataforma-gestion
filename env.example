# Variables de entorno para el proyecto

# ============================================
# ERP Manager+ Configuration
# ============================================
ERP_BASE_URL=https://axam.managermas.cl/api
ERP_USERNAME=
ERP_PASSWORD=
RUT_EMPRESA=

# ============================================
# Database Configuration (Prisma)
# ============================================
# ¡IMPORTANTE! Mantener estas rutas exactas para compatibilidad Docker/WSL
DATABASE_URL="file:../data/dev.db"
DB_PATH="./data/dev.db"

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
SYNC_CONCURRENCY=5
SYNC_MAX_RETRIES=3
