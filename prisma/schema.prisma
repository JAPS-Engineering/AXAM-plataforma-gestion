// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Producto {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  descripcion     String
  familia         String   @default("")
  proveedor       String   @default("")           // Nombre/código del proveedor
  stockMinimo     Float?   @map("stock_minimo") // Umbral para alerta de quiebre
  stockOptimo     Float?   @map("stock_optimo") // Nivel ideal de inventario
  factorEmpaque   Float    @default(1)   @map("factor_empaque") // Unidades por pallet/caja
  diasImportacion Int      @default(0)   @map("dias_importacion") // Tiempo de llegada (importados)
  origen          String   @default("NACIONAL")   // 'NACIONAL' o 'IMPORTADO'
  unidad          String   @default("U")          // Unidad de medida (U, gr, kg, etc.)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  ventasHistoricas   VentaHistorica[]
  ventasSemanales    VentaSemanal[] // Nueva relación
  ventasActuales     VentaActual[]
  comprasHistoricas  CompraHistorica[]
  stockHistorico     StockHistorico[]
  pedidos            Pedido[]
  ordenCompraItems   OrdenCompraItem[]

  // Campos para análisis de compras
  precioUltimaCompra Float?   @map("precio_ultima_compra")
  fechaUltimaCompra  DateTime? @map("fecha_ultima_compra")

  preciosListas      PrecioLista[]

  @@index([sku])
  @@index([familia])
  @@index([proveedor])
  @@index([origen])
  @@map("productos")
}

model PrecioLista {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  listaId         Int      @map("lista_id")     // 89, 652, 386, etc.
  precioNeto      Float    @map("precio_neto")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, listaId])
  @@map("precios_listas")
}

model VentaHistorica {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  ano             Int
  mes             Int      // 1-12
  vendedor        String   @default("")
  cantidadVendida Float    @default(0) @map("cantidad_vendida")
  montoNeto       Float    @default(0) @map("monto_neto")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  vendedorRel Vendedor? @relation(fields: [vendedor], references: [codigo])

  @@unique([productoId, ano, mes, vendedor])
  @@index([productoId])
  @@index([ano, mes])
  @@index([productoId, ano, mes])
  @@map("ventas_mensuales")
}

model VentaSemanal {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  ano             Int
  semana          Int      // 1-53
  vendedor        String   @default("")
  cantidadVendida Float    @default(0) @map("cantidad_vendida")
  montoNeto       Float    @default(0) @map("monto_neto")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  // No relation to Vendedor strictly needed for calculation, but could be added if needed. keeping simple.

  @@unique([productoId, ano, semana, vendedor])
  @@index([productoId])
  @@index([ano, semana])
  @@map("ventas_semanales")
}

model VentaActual {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  vendedor        String   @default("")
  cantidadVendida Float    @default(0) @map("cantidad_vendida")
  stockActual     Float    @default(0) @map("stock_actual")
  montoNeto       Float    @default(0) @map("monto_neto")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  vendedorRel Vendedor? @relation(fields: [vendedor], references: [codigo])

  @@unique([productoId, vendedor])
  @@index([productoId])
  @@map("ventas_actuales")
}

model Pedido {
  id         Int      @id @default(autoincrement())
  productoId Int      @map("producto_id")
  ano        Int
  mes        Int      // 1-12
  cantidad   Float    @default(0)
  tipo       String   @default("OC") // 'OC' | 'OCI'
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, ano, mes])
  @@index([productoId])
  @@index([ano, mes])
  @@index([productoId, ano, mes])
  @@map("pedidos")
}

model SyncLog {
  id                  Int      @id @default(autoincrement())
  tipo                String   // 'ventas_actuales' | 'ventas_historicas' | 'productos' | 'stock'
  mesTarget           Int      @map("mes_target") // Mes que se actualizó (1-12)
  anoTarget           Int      @map("ano_target") // Año que se actualizó
  documentos          Int      @default(0) // Cantidad de documentos procesados
  productos           Int      @default(0) // Cantidad de productos actualizados (stock, etc)
  productosConVentas  Int      @default(0) @map("productos_con_ventas") // Productos con ventas nuevas
  mensaje             String?  // Mensaje descriptivo opcional
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([tipo])
  @@index([createdAt])
  @@map("sync_logs")
}

// Configuración global del sistema
model Configuracion {
  id          Int      @id @default(autoincrement())
  clave       String   @unique  // Ej: 'algoritmo_default', 'timeframe_meses'
  valor       String            // Valor en formato string/JSON
  descripcion String?           // Descripción del parámetro
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("configuraciones")
}

// Orden de Compra generada
model OrdenCompra {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique           // Código único de la OC
  proveedor     String                     // Nombre del proveedor
  tipo          String   @default("NACIONAL") // 'NACIONAL' o 'IMPORTADO'
  estado        String   @default("PENDIENTE") // 'PENDIENTE' | 'GENERADA' | 'ENVIADA' | 'RECIBIDA'
  montoTotal    Float    @default(0) @map("monto_total")
  moneda        String   @default("CLP")    // 'CLP' o 'USD'
  observaciones String?
  fechaEmision  DateTime @default(now()) @map("fecha_emision")
  fechaEnvio    DateTime? @map("fecha_envio")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  items OrdenCompraItem[]

  @@index([proveedor])
  @@index([estado])
  @@index([tipo])
  @@index([fechaEmision])
  @@map("ordenes_compra")
}

// Detalle de productos en una Orden de Compra
model OrdenCompraItem {
  id            Int      @id @default(autoincrement())
  ordenCompraId Int      @map("orden_compra_id")
  productoId    Int      @map("producto_id")
  cantidad      Float                      // Cantidad a pedir
  precioUnit    Float    @default(0) @map("precio_unit") // Precio unitario
  subtotal      Float    @default(0)       // cantidad * precioUnit
  observaciones String?
  createdAt     DateTime @default(now()) @map("created_at")

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([ordenCompraId, productoId])
  @@index([ordenCompraId])
  @@index([productoId])
  @@map("orden_compra_items")
}


model CompraHistorica {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  fecha           DateTime
  cantidad        Float
  precioUnitario  Float    @map("precio_unitario")
  proveedor       String?
  rutProveedor    String?  @map("rut_proveedor")
  folio           String?  // Nro Factura
  tipoDoc         String   @default("FACE") @map("tipo_doc") // 'FACE' | 'FIM'
  createdAt       DateTime @default(now()) @map("created_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, folio, fecha])
  @@index([productoId])
  @@index([fecha])
  @@index([proveedor])
  @@index([tipoDoc])
  @@map("compras_historicas")
}

model StockHistorico {
  id              Int      @id @default(autoincrement())
  productoId      Int      @map("producto_id")
  fecha           DateTime // Fecha del snapshot (se toma a media noche)
  stock           Float
  createdAt       DateTime @default(now()) @map("created_at")

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@index([fecha])
  @@map("stock_historico")
}

// Metas definidas por Gerencia
model ObjetivoVenta {
  id            Int      @id @default(autoincrement())
  tipo          String   // 'VENDEDOR' | 'FAMILIA' | 'PROVEEDOR'
  entidadId     String   // ID o Nombre del Vendedor / Familia / Proveedor
  ano           Int
  mes           Int
  montoObjetivo Float    @default(0) @map("monto_objetivo")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([tipo, entidadId, ano, mes])
  @@map("objetivos_venta")
}

// "PROPONGO" - Forecast del Vendedor
model ProyeccionVenta {
  id            Int      @id @default(autoincrement())
  vendedorId    String   @map("vendedor_id") // ID del Vendedor
  ano           Int
  mes           Int
  montoPropongo Float    @default(0) @map("monto_propongo") // La estimación del vendedor
  observacion   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  vendedorRel   Vendedor? @relation(fields: [vendedorId], references: [codigo])

  @@unique([vendedorId, ano, mes])
  @@map("proyecciones_venta")
}

// Gestión de Vendedores (Nombres/Apodos)
model Vendedor {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique // Sigla original de Manager+ (ms, hm, etc)
  nombre    String?          // Apodo o nombre legible
  activo    Boolean  @default(true)
  oculto    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ventasHistoricas VentaHistorica[]
  ventasActuales   VentaActual[]
  proyecciones     ProyeccionVenta[]

  @@map("vendedores")
}

// Destinatarios de notificaciones por email
model EmailNotificacion {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  tipo      String   @default("STOCK_BAJO") // STOCK_BAJO, etc.
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_notificaciones")
}
